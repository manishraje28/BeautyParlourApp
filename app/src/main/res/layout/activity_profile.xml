<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_background_pink"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            style="@style/AppTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile" />

        <LinearLayout
            android:id="@+id/layout_logged_out"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="visible">

            <TextView
                style="@style/AppBodyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="You are not logged in." />

            <Button
                android:id="@+id/btn_go_login"
                style="@style/AppPrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="Login" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_logged_in"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <!-- Avatar: ImageView + pencil edit button overlay -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp">

                <!-- Gesture 5: Pinch Zoom target -->
                <ImageView
                    android:id="@+id/img_avatar"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/bg_profile_placeholder"
                    android:scaleType="centerCrop" />

                <!-- Tap to pick a new photo from gallery -->
                <TextView
                    android:id="@+id/btn_change_photo"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|end"
                    android:background="@color/dark_pink"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="&#10000;"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

            </FrameLayout>

            <TextView
                android:id="@+id/tv_profile_name"
                style="@style/AppSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Name" />

            <TextView
                android:id="@+id/tv_profile_email"
                style="@style/AppBodyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="email@example.com" />

            <Button
                android:id="@+id/btn_logout"
                style="@style/AppPrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:text="Logout" />
        </LinearLayout>

        <!-- Gesture 4: Swipe Left/Right hint -->
        <TextView
            style="@style/AppBodyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:alpha="0.55"
            android:gravity="center"
            android:text="&#8592; Swipe left to Book  |  Swipe right for Home &#8594;"
            android:textSize="12sp" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/footer_container"
        android:layout_width="match_parent"
        android:layout_height="72dp" />

</LinearLayout>
