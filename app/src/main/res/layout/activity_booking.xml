<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_background_pink"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                style="@style/AppTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Book Appointment" />

            <TextView
                style="@style/AppBodyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Choose your preferred service, date and time." />

            <TextView
                style="@style/AppLabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Select Service" />

            <Spinner
                android:id="@+id/spinner_service"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_rounded"
                android:padding="12dp" />

            <TextView
                style="@style/AppLabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Select Date" />

            <Button
                android:id="@+id/btn_pick_date"
                style="@style/AppPrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Choose Date" />

            <TextView
                android:id="@+id/tv_selected_date"
                style="@style/AppBodyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/not_selected" />

            <TextView
                style="@style/AppLabelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Select Time" />

            <Button
                android:id="@+id/btn_pick_time"
                style="@style/AppPrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="Choose Time" />

            <TextView
                android:id="@+id/tv_selected_time"
                style="@style/AppBodyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/not_selected" />

            <Button
                android:id="@+id/btn_book"
                style="@style/AppPrimaryButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:text="Book Appointment" />

        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/footer_container"
        android:layout_width="match_parent"
        android:layout_height="72dp" />

</LinearLayout>