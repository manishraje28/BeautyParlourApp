<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_background_pink"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                style="@style/AppTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/salon_name" />

            <TextView
                style="@style/AppBodyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Experience beauty and relaxation with expert stylists, premium products, and personalized care." />

            <TextView
                style="@style/AppSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Popular Services" />

            <TextView
                style="@style/AppCardText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card"
                android:text="Haircut - ₹499\nClassic styling and finish in 45 mins." />

            <TextView
                style="@style/AppCardText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card"
                android:text="Facial - ₹899\nGlow-enhancing skincare for all skin types." />

            <TextView
                style="@style/AppCardText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_card"
                android:text="Bridal Makeup - ₹5999\nComplete bridal look by certified artists." />

        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/footer_container"
        android:layout_width="match_parent"
        android:layout_height="72dp" />

</LinearLayout>